<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EditPostActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Current image preview -->
        <ImageView
            android:id="@+id/ivEditPreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:contentDescription="@string/post_image"
            android:layout_marginBottom="16dp"
            android:src="@drawable/post_placeholder" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_post_title"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etEditTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_post_title"
            android:inputType="textCapSentences"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_post_description"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etEditDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_post_description"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_image_res"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etEditImageRes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_image_res_optional"
            android:inputType="textNoSuggestions"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnUpdatePost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/update_post"
            style="@style/Widget.MaterialComponents.Button" />

        <TextView
            android:id="@+id/tvEditStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="14sp"
            android:text="" />

    </LinearLayout>

</ScrollView>
