<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".EditPostActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarEditPost"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Current image preview -->
            <ImageView
                android:id="@+id/ivEditPreview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:contentDescription="@string/post_image"
                android:src="@drawable/post_placeholder"
                android:layout_marginBottom="8dp" />

            <!-- Pick new image button -->
            <Button
                android:id="@+id/btnPickImageEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/change_image"
                android:layout_marginBottom="16dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_post_title"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etEditTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_post_title"
                android:inputType="textCapSentences"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_post_description"
                android:textStyle="bold"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etEditDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_post_description"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:gravity="top"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnUpdatePost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_post"
                style="@style/Widget.MaterialComponents.Button" />

            <TextView
                android:id="@+id/tvEditStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="14sp"
                android:text="" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
