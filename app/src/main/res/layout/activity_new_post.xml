<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NewPostActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_post_title"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etNewPostTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_post_title"
            android:inputType="textCapSentences"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_post_description"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etNewPostDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_post_description"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hint_image_res"
            android:textStyle="bold"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etNewPostImageRes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_image_res_optional"
            android:inputType="textNoSuggestions"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnSavePost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_post"
            style="@style/Widget.MaterialComponents.Button" />

        <TextView
            android:id="@+id/tvNewPostStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="14sp"
            android:text="" />

    </LinearLayout>

</ScrollView>
